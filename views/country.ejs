<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= city.name %> - Şehir Detayları</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-100">
    <%- include('partials/header') %>

    <div class="container mx-auto px-4 py-8">
        <h1 class="text-4xl font-bold mb-4"><%= city.name %></h1>
        <img src="<%= city.imageUrl %>" alt="<%= city.name %>" class="w-64 h-40 object-cover rounded-lg mb-4 shadow-md">
        
        <h2 class="text-2xl font-semibold mb-2">Hakkında</h2>
        <p class="mb-4"><%= city.description %></p>

        <h2 class="text-2xl font-semibold mb-2">Ziyaret Bilgileri</h2>
        <p><strong>Ziyaret Süresi:</strong> <%= city.visitDuration %></p>
        <p><strong>Fiyat:</strong> <%= city.price %></p>
        <p><strong>Açılış Saatleri:</strong> <%= city.openingHours %></p>

        <h2 class="text-2xl font-semibold mb-2">Kategori ve Tür</h2>
        <p><strong>Kategori:</strong> <%= city.location.category %></p>
        <p><strong>Tür:</strong> <%= city.location.type %></p>
    </div>

    <!-- Benzer Şehirler -->
    <% if (relatedCities && relatedCities.length > 0) { %>
        <section class="container mx-auto px-4 py-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-8">Benzer Şehirler</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <% relatedCities.forEach(relatedCity => { %>
                    <a href="/sehir/<%= relatedCity.slug %>" class="group">
                        <div class="relative rounded-lg overflow-hidden shadow-md">
                            <img 
                                src="<%= relatedCity.imageUrl %>" 
                                alt="<%= relatedCity.name %>" 
                                class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                            >
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-4">
                                <h3 class="text-xl font-semibold text-white"><%= relatedCity.name %></h3>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        </section>
    <% } %>

    <%- include('partials/footer') %>
</body>
</html>
