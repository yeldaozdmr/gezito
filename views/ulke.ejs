<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= country.name %> Detayları</title>
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
    
</head>
<body class="bg-gray-100">
    <%- include('partials/header') %>

    <div class="container mx-auto px-4 py-16">
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <img src="<%= country.flagUrl %>" alt="<%= country.name %>" class="w-full h-48 object-cover">
            <div class="p-4">
                <h1 class="text-3xl font-bold text-gray-900"><%= country.name %></h1>
                <p class="text-gray-600 mt-2"><%= country.description %></p>
                <h2 class="text-xl font-semibold mt-4">Öne Çıkan Yerler</h2>
                <ul class="list-disc list-inside mt-2">
                    <% country.highlights.forEach(highlight => { %>
                        <li class="text-gray-600"><%= highlight %></li>
                    <% }); %>
                </ul>
                <h2 class="text-xl font-semibold mt-4">Gezilecek Şehirler</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
                    <% country.cities.forEach(city => { %>
                        <div class="bg-white rounded-lg shadow-md overflow-hidden">
                            <img src="<%= city.imageUrl %>" alt="<%= city.name %>" class="w-full h-32 object-cover">
                            <div class="p-4">
                                <h3 class="text-lg font-semibold"><%= city.name %></h3>
                                <p class="text-gray-600"><%= city.description %></p>
                                <a href="/sehir/<%= city.slug %>" class="text-blue-500 hover:underline">Detaylar</a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>