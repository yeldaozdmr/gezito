<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gezito</title>
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>


    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W9RRLE5Q83"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W9RRLE5Q83');
    </script>
</head>
<body>

<header class="bg-white shadow-sm">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center -my-6">
                <img 
                    src="/images/logo.png"
                    alt="Gezito Logo" 
                    class="h-20 w-auto"
                />
            </a>

            <!-- Navigation -->
            <nav class="hidden md:flex space-x-8">
                <a href="/browse/country"  class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase">Ülkeler</a>
                <a href="/browse/city"  class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase">Şehirler</a>
                <a href="/iletisim"  class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase">İletişim</a>
            </nav>

            <!-- Arama Çubuğu -->
           
            <!-- Giriş -->
            <div class="w-48 flex justify-end">
                <a href="/giris" class="flex items-center space-x-2 text-gray-600 hover:text-yellow-600 p-2 group">
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span class="text-sm font-light tracking-wider uppercase">Sign In</span>
                </a>
            </div>
        </div>
    </div>
</header>

<script>
let isDropdownOpen = false;

function toggleDropdown(event) {
    event.stopPropagation();
    const dropdown = document.getElementById('regionDropdown');

    if (!isDropdownOpen) {
        dropdown.classList.remove('hidden');
        isDropdownOpen = true;
    } else {
        dropdown.classList.add('hidden');
        isDropdownOpen = false;
    }
}

// Dropdown dışına tıklandığında kapanmasını sağla
document.addEventListener('click', (event) => {
    const dropdown = document.getElementById('regionDropdown');
    const button = document.getElementById('regionButton');
    
    if (isDropdownOpen && !dropdown.contains(event.target) && !button.contains(event.target)) {
        dropdown.classList.add('hidden');
        isDropdownOpen = false;
    }
});

// Arama işlevi
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchForm = document.getElementById('searchForm');

    if (searchInput && searchResults && searchForm) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.trim();
            performSearch(searchTerm);
        });

        searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const searchTerm = searchInput.value.trim();
            if (searchTerm) {
                window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
            }
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.add('hidden');
            }
        });
    } else {
        console.error('searchInput, searchResults veya searchForm öğesi bulunamadı.');
    }
});

// Dropdown bağlantılarına tıklama işlevi
document.querySelectorAll('#regionDropdown a').forEach(link => {
    link.addEventListener('click', (event) => {
        event.stopPropagation(); // Dropdown'un kapanmasını engelle
        const url = link.getAttribute('href'); // Bağlantının URL'sini al
        window.location.href = url; // Sayfayı yeni URL'ye yönlendir
    });
});
</script>

<style>
/* Hover efektleri */
.hover\:text-yellow-600:hover {
    color: #CA8A04;
}

/* Dropdown transition */
#regionDropdown {
    transition: all 0.2s ease-in-out;
}

/* Active state için stil */
.text-yellow-600 {
    color: #CA8A04;
}

/* Font ayarları */
.tracking-wider {
    letter-spacing: 0.05em;
}

/* Sign in hover efekti */
.group:hover svg {
    transform: scale(1.1);
}

/* styles.css */
.relative:hover .absolute {
    display: block; /* Hover durumunda açılır menüyü göster */
}
</style>

</body>
</html>
