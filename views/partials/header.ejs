<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="K96OdbqPPG-9eR_8yvicAmS3w59I2-QkGONW-Vudobc" />
    <title>Gezito</title>
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W9RRLE5Q83"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W9RRLE5Q83');
    </script>
</head>
<body>

<header class="bg-white shadow-sm">
    <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center -my-6">
                <img 
                    src="/images/logo.png"
                    alt="Gezito Logo" 
                    class="h-20 w-auto"
                />
            </a>

            <!-- Navigation -->
            <nav class="hidden md:flex space-x-8">
                <div class="relative">
                    <button 
                        id="regionButton"
                        class="flex items-center space-x-2 text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase"
                        onclick="toggleDropdown(event)"
                    >
                        <span>Rehberler</span>
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                    <div id="regionDropdown" class="hidden absolute w-48 bg-white shadow-sm rounded-md mt-1 py-1 z-50 left-0 border border-gray-100">
                        <a href="/browse/country" class="block px-4 py-2 text-gray-600 hover:bg-gray-50 text-sm tracking-wide">Ülkeler</a>
                        <a href="/browse/city" class="block px-4 py-2 text-gray-600 hover:bg-gray-50 text-sm tracking-wide">Şehirler</a>
                    </div>
                </div>

                <a href="https://tr.hotels.com" target="_blank" class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase">Otel</a>
                <a href="https://www.enuygun.com/ucak-bileti/" target="_blank" class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase">Uçak</a>
                <a href="https://www.enuygun.com/arac-kiralama/" target="_blank" class="text-gray-600 hover:text-yellow-600 font-light text-base tracking-wider uppercase whitespace-nowrap">Araç Kiralama</a>
            </nav>

            <!-- Arama Çubuğu -->
            <nav class="navbar navbar-light bg-light fixed-top">
                <form id="searchForm" class="form-inline">
                    <input id="searchInput" class="form-control mr-sm-2 border border-black rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-yellow-500 w-64" type="search" placeholder="Ara..." aria-label="Search">
                    <button class="btn btn-outline-success my-2 my-sm-0" type="submit" style="color: green;">Ara</button>
                </form>
                <div id="searchResults" class="hidden"></div>
            </nav>

            <!-- Giriş -->
            <div class="w-48 flex justify-end">
                <a href="/giris" class="flex items-center space-x-2 text-gray-600 hover:text-yellow-600 p-2 group">
                    <svg class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    <span class="text-sm font-light tracking-wider uppercase">Sign In</span>
                </a>
            </div>
        </div>
    </div>
</header>

<script>
let isDropdownOpen = false;

function toggleDropdown(event) {
    event.stopPropagation();
    const dropdown = document.getElementById('regionDropdown');

    if (!isDropdownOpen) {
        dropdown.classList.remove('hidden');
        isDropdownOpen = true;
    } else {
        dropdown.classList.add('hidden');
        isDropdownOpen = false;
    }
}

// Dropdown dışına tıklandığında kapanmasını sağla
document.addEventListener('click', (event) => {
    const dropdown = document.getElementById('regionDropdown');
    const button = document.getElementById('regionButton');
    
    if (isDropdownOpen && !dropdown.contains(event.target) && !button.contains(event.target)) {
        dropdown.classList.add('hidden');
        isDropdownOpen = false;
    }
});

// Arama işlevi
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchForm = document.getElementById('searchForm');

    if (searchInput && searchResults && searchForm) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.trim();
            performSearch(searchTerm);
        });

        searchForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const searchTerm = searchInput.value.trim();
            if (searchTerm) {
                window.location.href = `/search?q=${encodeURIComponent(searchTerm)}`;
            }
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.add('hidden');
            }
        });
    } else {
        console.error('searchInput, searchResults veya searchForm öğesi bulunamadı.');
    }
});

// Dropdown bağlantılarına tıklama işlevi
document.querySelectorAll('#regionDropdown a').forEach(link => {
    link.addEventListener('click', (event) => {
        event.stopPropagation(); // Dropdown'un kapanmasını engelle
        const url = link.getAttribute('href'); // Bağlantının URL'sini al
        window.location.href = url; // Sayfayı yeni URL'ye yönlendir
    });
});
</script>

<style>
/* Hover efektleri */
.hover\:text-yellow-600:hover {
    color: #CA8A04;
}

/* Dropdown transition */
#regionDropdown {
    transition: all 0.2s ease-in-out;
}

/* Active state için stil */
.text-yellow-600 {
    color: #CA8A04;
}

/* Font ayarları */
.tracking-wider {
    letter-spacing: 0.05em;
}

/* Sign in hover efekti */
.group:hover svg {
    transform: scale(1.1);
}
</style>

</body>
</html>
